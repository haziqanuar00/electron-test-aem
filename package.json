{
  "name": "aem-electron-test",
  "version": "1.0.0",
  "description": "AEM Enersol Electron Interview Test - desktop login app consuming the AEM test API with PouchDB offline fallback",
  "main": "main.js",
  "author": "Haziq",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.aemenersol.electrontest",
    "productName": "AEM Electron Test",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!**/.git/**"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "pouchdb": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
